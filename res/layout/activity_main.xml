<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F7FF">

    <!-- ===== SCROLLABLE CONTENT (sits above bottom nav) ===== -->
    <ScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== PURPLE HEADER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/header_purple_bg"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="44dp"
                android:paddingBottom="24dp"
                android:orientation="vertical">

                <!-- Top row: avatar + title + logout -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/avatar_bg"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvAvatarLetter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="S"
                            android:textColor="#7C3AED"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-black"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Home"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"/>

                    <ImageButton
                        android:id="@+id/btnLogout"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/icon_btn_bg"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        android:contentDescription="Logout"
                        app:tint="#FFFFFF"/>
                </LinearLayout>

                <!-- Balance Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#5B21B6">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Balance row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Total Balance"
                                    android:textColor="#DDD6FE"
                                    android:textSize="11sp"/>
                                <TextView
                                    android:id="@+id/tvTotalBalance"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹0.00"
                                    android:textColor="#FFFFFF"
                                    android:textSize="26sp"
                                    android:fontFamily="sans-serif-black"/>
                            </LinearLayout>

                            <!-- Card circles -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <View android:layout_width="22dp" android:layout_height="22dp"
                                    android:background="@drawable/circle_orange"/>
                                <View android:layout_width="22dp" android:layout_height="22dp"
                                    android:background="@drawable/circle_orange_light"
                                    android:layout_marginStart="-8dp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Stats row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="16dp">

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:text="Income" android:textColor="#DDD6FE"
                                    android:textSize="10sp" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"/>
                                <TextView android:id="@+id/tvBalanceIncome" android:text="₹0"
                                    android:textColor="#FFFFFF" android:textSize="13sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            </LinearLayout>

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:text="Spent" android:textColor="#DDD6FE"
                                    android:textSize="10sp" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"/>
                                <TextView android:id="@+id/tvBalanceSpent" android:text="₹0"
                                    android:textColor="#FCA5A5" android:textSize="13sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            </LinearLayout>

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:text="Savings" android:textColor="#DDD6FE"
                                    android:textSize="10sp" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"/>
                                <TextView android:id="@+id/tvBalanceSavings" android:text="₹0"
                                    android:textColor="#6EE7B7" android:textSize="13sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ===== WHITE BODY ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="20dp">

                <!-- Quick Category Chips -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quick Add"
                    android:textColor="#1E1B4B"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">

                    <Button android:id="@+id/chipFood"
                        android:layout_width="0dp" android:layout_height="36dp"
                        android:layout_weight="1" android:layout_marginEnd="8dp"
                        android:text="Food" android:textSize="11sp"
                        android:textAllCaps="false" android:textColor="#7C3AED"
                        android:backgroundTint="#F5F3FF" app:cornerRadius="20dp"/>

                    <Button android:id="@+id/chipTravel"
                        android:layout_width="0dp" android:layout_height="36dp"
                        android:layout_weight="1" android:layout_marginEnd="8dp"
                        android:text="Travel" android:textSize="11sp"
                        android:textAllCaps="false" android:textColor="#EA580C"
                        android:backgroundTint="#FFF7ED" app:cornerRadius="20dp"/>

                    <Button android:id="@+id/chipShopping"
                        android:layout_width="0dp" android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Shop" android:textSize="11sp"
                        android:textAllCaps="false" android:textColor="#0369A1"
                        android:backgroundTint="#F0F9FF" app:cornerRadius="20dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="24dp">

                    <Button android:id="@+id/chipHealth"
                        android:layout_width="0dp" android:layout_height="36dp"
                        android:layout_weight="1" android:layout_marginEnd="8dp"
                        android:text="Health" android:textSize="11sp"
                        android:textAllCaps="false" android:textColor="#DC2626"
                        android:backgroundTint="#FEF2F2" app:cornerRadius="20dp"/>

                    <Button android:id="@+id/chipBills"
                        android:layout_width="0dp" android:layout_height="36dp"
                        android:layout_weight="1" android:layout_marginEnd="8dp"
                        android:text="Bills" android:textSize="11sp"
                        android:textAllCaps="false" android:textColor="#7C3AED"
                        android:backgroundTint="#F5F3FF" app:cornerRadius="20dp"/>

                    <Button android:id="@+id/chipEntertainment"
                        android:layout_width="0dp" android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Fun" android:textSize="11sp"
                        android:textAllCaps="false" android:textColor="#BE185D"
                        android:backgroundTint="#FDF2F8" app:cornerRadius="20dp"/>
                </LinearLayout>

                <!-- Divider -->
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F1F5F9" android:layout_marginBottom="20dp"/>

                <!-- Amount -->
                <TextView android:text="Amount (₹)" android:textColor="#6D28D9"
                    android:textSize="12sp" android:fontFamily="sans-serif-medium"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/amount"
                    android:layout_width="match_parent" android:layout_height="54dp"
                    android:hint="0.00" android:textColor="#1E1B4B"
                    android:textSize="20sp" android:fontFamily="sans-serif-black"
                    android:inputType="numberDecimal"
                    android:background="@drawable/input_white_bg"
                    android:paddingStart="16dp" android:paddingEnd="16dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Category -->
                <TextView android:text="Category" android:textColor="#6D28D9"
                    android:textSize="12sp" android:fontFamily="sans-serif-medium"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/category"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:hint="e.g. Food, Travel, Shopping" android:textColor="#1E1B4B"
                    android:inputType="textCapSentences"
                    android:background="@drawable/input_white_bg"
                    android:paddingStart="16dp" android:paddingEnd="16dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Description -->
                <TextView android:text="Description (optional)" android:textColor="#6D28D9"
                    android:textSize="12sp" android:fontFamily="sans-serif-medium"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/etDescription"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:hint="What was this for?" android:textColor="#1E1B4B"
                    android:inputType="textCapSentences"
                    android:background="@drawable/input_white_bg"
                    android:paddingStart="16dp" android:paddingEnd="16dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Date -->
                <TextView android:text="Date" android:textColor="#6D28D9"
                    android:textSize="12sp" android:fontFamily="sans-serif-medium"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/date"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:hint="Tap to select date" android:textColor="#1E1B4B"
                    android:focusable="false" android:clickable="true"
                    android:background="@drawable/input_white_bg"
                    android:paddingStart="16dp" android:paddingEnd="16dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Payment Mode -->
                <TextView android:text="Payment Mode" android:textColor="#6D28D9"
                    android:textSize="12sp" android:fontFamily="sans-serif-medium"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"/>
                <Spinner android:id="@+id/modeSpinner"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:background="@drawable/input_white_bg"
                    android:paddingStart="16dp"
                    android:layout_marginBottom="24dp"/>

                <!-- Save Button -->
                <Button android:id="@+id/saveBtn"
                    android:layout_width="match_parent" android:layout_height="54dp"
                    android:text="Save Expense"
                    android:textAllCaps="false" android:textSize="16sp"
                    android:textColor="#FFFFFF" android:backgroundTint="#7C3AED"
                    android:layout_marginBottom="12dp" app:cornerRadius="14dp"/>

                <!-- Analytics Button -->
                <Button android:id="@+id/viewAnalytics"
                    android:layout_width="match_parent" android:layout_height="54dp"
                    android:text="View Analytics"
                    android:textAllCaps="false" android:textSize="16sp"
                    android:textColor="#7C3AED" android:backgroundTint="#F5F3FF"
                    app:cornerRadius="14dp"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- ===== BOTTOM NAV — pinned to bottom via RelativeLayout ===== -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bottom_nav_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <!-- Home -->
        <LinearLayout android:id="@+id/navHome"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center"
            android:orientation="vertical" android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="#7C3AED"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Home" android:textSize="9sp" android:textColor="#7C3AED"
                android:layout_marginTop="2dp"/>
            <View android:layout_width="6dp" android:layout_height="3dp"
                android:background="@drawable/nav_dot" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Analytics -->
        <LinearLayout android:id="@+id/navAnalytics"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center"
            android:orientation="vertical" android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_recent_history"
                app:tint="#94A3B8"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Analytics" android:textSize="9sp" android:textColor="#94A3B8"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- FAB (orange add button) -->
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center">
            <androidx.cardview.widget.CardView
                android:id="@+id/fabAdd"
                android:layout_width="48dp" android:layout_height="48dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="#F97316"
                app:cardElevation="6dp">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                    android:gravity="center" android:text="+"
                    android:textColor="#FFFFFF" android:textSize="24sp"
                    android:fontFamily="sans-serif-medium"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Settings -->
        <LinearLayout android:id="@+id/navProfile"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center"
            android:orientation="vertical" android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="#94A3B8"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Settings" android:textSize="9sp" android:textColor="#94A3B8"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Logout -->
        <LinearLayout android:id="@+id/navLogout"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center"
            android:orientation="vertical" android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#94A3B8"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Logout" android:textSize="9sp" android:textColor="#94A3B8"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>