<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F7FF"
    android:orientation="vertical">

    <!-- ===== PURPLE HEADER ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/header_purple_bg"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="44dp"
        android:paddingBottom="20dp"
        android:orientation="vertical">

        <!-- Title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/icon_btn_bg"
                android:src="@android:drawable/ic_media_previous"
                android:contentDescription="Back"
                android:layout_marginEnd="12dp"
                app:tint="#FFFFFF"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Analytics"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"/>

            <Button
                android:id="@+id/btnPickYear"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="📅 2026"
                android:textSize="11sp"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                app:strokeColor="#DDD6FE"
                android:layout_marginEnd="8dp"/>

            <ImageButton
                android:id="@+id/btnSetBudget"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/icon_btn_bg"
                android:src="@android:drawable/ic_menu_manage"
                android:contentDescription="Budget"
                app:tint="#FFFFFF"/>
        </LinearLayout>

        <!-- Summary cards row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- Income card -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#5B21B6"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView android:text="Total Salary"
                        android:textColor="#DDD6FE" android:textSize="10sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvIncomeCard"
                        android:text="₹0" android:textColor="#FFFFFF"
                        android:textSize="18sp" android:fontFamily="sans-serif-black"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="Bank Account"
                        android:textColor="#A78BFA" android:textSize="9sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Expense card -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#EA580C"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView android:text="Total Expense"
                        android:textColor="#FED7AA" android:textSize="10sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/totalExpense"
                        android:text="₹0" android:textColor="#FFFFFF"
                        android:textSize="18sp" android:fontFamily="sans-serif-black"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="Bank Account"
                        android:textColor="#FDBA74" android:textSize="9sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </LinearLayout>

    <!-- ===== SCROLLABLE BODY ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Filter row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <Spinner
                    android:id="@+id/filterSpinner"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_white_bg"
                    android:paddingStart="12dp"
                    android:layout_marginEnd="8dp"/>
            </LinearLayout>

            <!-- Budget progress card -->
            <LinearLayout
                android:id="@+id/budgetCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/budget_card_white_bg"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="20dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="You have spent "
                        android:textColor="#64748B"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvSpentHighlight"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹0"
                        android:textColor="#F97316"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-black"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text=" this month."
                        android:textColor="#64748B"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvBudgetPct"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="#7C3AED"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-black"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/budgetProgress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:max="100"
                    android:progress="0"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="Budget Remaining"
                            android:textColor="#94A3B8" android:textSize="10sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/budgetLeft"
                            android:text="Set budget ⚙"
                            android:textColor="#7C3AED" android:textSize="18sp"
                            android:fontFamily="sans-serif-black"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="Savings"
                            android:textColor="#94A3B8" android:textSize="10sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/totalSavings"
                            android:text="Not set"
                            android:textColor="#10B981" android:textSize="18sp"
                            android:fontFamily="sans-serif-black"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvBudgetInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tap here to set your income and monthly budget"
                    android:textSize="10sp"
                    android:textColor="#94A3B8"
                    android:layout_marginTop="8dp"/>

                <!-- Stats row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">
                    <TextView android:id="@+id/tvTransactionCount"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0 Transactions"
                        android:textColor="#64748B" android:textSize="11sp"/>
                    <TextView android:id="@+id/tvAvgExpense"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Avg: ₹0"
                        android:textColor="#64748B" android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Section: Category Breakdown -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Category Breakdown"
                    android:textColor="#1E1B4B"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-black"/>
                <TextView
                    android:id="@+id/tvViewAllCat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View All"
                    android:textColor="#7C3AED"
                    android:textSize="12sp"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="4dp"
                android:layout_marginBottom="20dp">
                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/pieChart"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"/>
            </androidx.cardview.widget.CardView>

            <!-- Section: Payment Modes -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Payment Modes"
                android:textColor="#1E1B4B"
                android:textSize="14sp"
                android:fontFamily="sans-serif-black"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="4dp"
                android:layout_marginBottom="20dp">
                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/modeChart"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"/>
            </androidx.cardview.widget.CardView>

            <!-- Section: Monthly Trend -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monthly Trend"
                android:textColor="#1E1B4B"
                android:textSize="14sp"
                android:fontFamily="sans-serif-black"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="4dp"
                android:layout_marginBottom="20dp">
                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/barChart"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"/>
            </androidx.cardview.widget.CardView>

            <!-- Section: Transactions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Transactions"
                    android:textColor="#1E1B4B"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-black"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Last 50"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="4dp"
                android:layout_marginBottom="24dp">
                <LinearLayout
                    android:id="@+id/transactionList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp"/>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>