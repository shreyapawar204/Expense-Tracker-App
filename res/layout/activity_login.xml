<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Purple header banner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/header_purple_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💸"
                android:textSize="44sp"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SpendSmart"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:fontFamily="sans-serif-black"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Track. Analyze. Save."
                android:textColor="#DDD6FE"
                android:textSize="13sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Form area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome Back 👋"
                android:textColor="#1E1B4B"
                android:textSize="22sp"
                android:fontFamily="sans-serif-black"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign in to your account"
                android:textColor="#94A3B8"
                android:textSize="13sp"
                android:layout_marginBottom="24dp"/>

            <!-- Name (register) -->
            <LinearLayout
                android:id="@+id/nameLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full Name"
                    android:textColor="#6D28D9"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="John Doe"
                    android:textColor="#1E1B4B"
                    android:inputType="textPersonName|textCapWords"
                    android:background="@drawable/input_white_bg"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="16dp"/>
            </LinearLayout>

            <!-- Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email Address"
                android:textColor="#6D28D9"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="you@example.com"
                android:textColor="#1E1B4B"
                android:inputType="textEmailAddress"
                android:background="@drawable/input_white_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp"/>

            <!-- Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textColor="#6D28D9"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="••••••••"
                android:textColor="#1E1B4B"
                android:inputType="textPassword"
                android:background="@drawable/input_white_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp"/>

            <!-- Confirm Password (register) -->
            <LinearLayout
                android:id="@+id/confirmLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Confirm Password"
                    android:textColor="#6D28D9"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etConfirmPass"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="••••••••"
                    android:textColor="#1E1B4B"
                    android:inputType="textPassword"
                    android:background="@drawable/input_white_bg"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="16dp"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnAction"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Sign In"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#7C3AED"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                app:cornerRadius="14dp"/>

            <TextView
                android:id="@+id/tvToggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Don't have an account? Register"
                android:textColor="#7C3AED"
                android:textSize="13sp"
                android:padding="8dp"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>